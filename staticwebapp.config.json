{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": ["/data/*", "/*.{css,js,ico,svg,png,jpg,jpeg,gif,webp,woff,woff2}"]
    },
    "mimeTypes": {
        ".json": "application/json"
    },
    "globalHeaders": {
        "Cache-Control": "no-cache",
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin"
    }
}
